# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com


# Ark API Configuration (OpenAI compatible)
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3


# MySQL Connection (for future database integration)
MYSQL_CONNECTION=mysql://user:password@localhost:3306/database_name


# Zhipu AI Configuration
ZHIPU_API_KEY=your_zhipu_api_key_here


# LangSmith Tracing (Optional for debugging)
LANGSMITH_API_KEY=lsv2_your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langgraph-demo


# Debug Settings
DEBUG=true
VERBOSE=false
